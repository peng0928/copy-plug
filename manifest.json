{
  "manifest_version": 3,
  "name": "Free Copy",
  "version": "1.0",
  "description": "Ctrl+E 开启/关闭复制限制解除",
  "icons": {
    "16": "images/image.png",
    "48": "images/image.png",
    "128": "images/image.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injector.js", "images/*.png"],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}